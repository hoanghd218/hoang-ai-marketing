# Environment Variables Template
# Copy this file to .env and fill in your actual API keys
# NEVER commit .env to git - it's in .gitignore

# Notion Integration
NOTION_API_KEY=ntn_your_notion_integration_token_here
NOTION_DATABASE_ID=your_database_id_here
NOTION_DATABASE_VIDEO_TREND_ID=your_video_trend_database_id_here
NOTION_DATASOURCE_VIDEO_TREND_ID=your_video_trend_datasource_id_here

# OpenRouter API
OPENROUTER_API_KEY=sk-or-v1-your_openrouter_api_key_here

# YouTube Data API
YOUTUBE_API_KEY=your_youtube_data_api_v3_key_here

# xAI Grok API (for X.com trending posts search)
XAI_API_KEY=xai-your_xai_api_key_here

# Perplexity API (for AI news aggregation)
PERPLEXITY_API_KEY=pplx-your_perplexity_api_key_here

# Optional: Other API keys as needed
# OPENAI_API_KEY=
