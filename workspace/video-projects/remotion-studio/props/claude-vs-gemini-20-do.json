      "highlights": ["hạn chế"],
      "style": "normal",
      "textEffect": "flicker"
    },
    {
      "text": "Claude dạo này hạn chế lượt dùng khá gắt ở giờ cao điểm.",
      "startSec": 49.72,
      "endSec": 52.22,
      "highlights": ["hạn chế"],
      "style": "normal",
      "textEffect": "flicker"
    },
    {
      "text": "Làm task dài dễ bị dừng giữa chừng.",
