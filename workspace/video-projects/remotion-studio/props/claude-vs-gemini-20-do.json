      "style": "pain",
      "textEffect": "flicker"
    },
    {
      "text": "Viết bài thì ra giọng máy, tra cứu thì thiếu nguồn, cần ảnh thì không có.",
      "startSec": 12.24,
      "endSec": 14.76,
      "highlights": ["giọng máy"],
      "style": "pain",
      "textEffect": "flicker"
    },
    {
      "text": "Mất thời gian copy qua copy lại giữa mấy con AI khác nhau.",
