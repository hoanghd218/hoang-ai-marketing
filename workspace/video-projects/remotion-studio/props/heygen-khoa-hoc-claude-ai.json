  "captions": [
    {
      "text": "Một ông chủ kiếm 4 triệu đô mỗi năm nhờ AI,",
      "startSec": 0.0, "endSec": 1.9,
      "style": "hook",
      "highlights": ["4 triệu đô", "AI"],
      "textEffect": "word-by-word"
    },
    {
      "text": "vừa tung ra KHÓA HỌC Claude AI dài 4 tiếng — hoàn toàn miễn phí.",
      "startSec": 1.9, "endSec": 4.56,
      "style": "hook",
      "highlights": ["KHÓA HỌC", "miễn phí"],
      "textEffect": "word-by-word"
    },
    {
      "text": "Hơn 1 triệu lượt xem. Và mình vừa xem xong.",
      "startSec": 4.56, "endSec": 6.32,
      "style": "normal",
      "highlights": ["1 triệu"],
      "textEffect": "word-by-word"
    },
    {
      "text": "Mà cái hay là ổng không giữ lại cho riêng mình.",
      "startSec": 6.32, "endSec": 8.82,
      "style": "normal",
      "highlights": ["cái hay"],
      "textEffect": "word-by-word"
    },
    {
      "text": "Ông Nick Saraev này — 6 năm xây doanh nghiệp tự động hóa,",
      "startSec": 8.82, "endSec": 11.44,
      "style": "normal",
      "highlights": ["6 năm"],
      "textEffect": "word-by-word"
    },
    {
      "text": "công ty 7 chữ số — ổng chia sẻ hết cho mọi người.",
      "startSec": 11.44, "endSec": 13.54,
      "style": "solution",
      "highlights": ["7 chữ số", "chia sẻ hết"],
      "textEffect": "word-by-word"
    },
    {
      "text": "Ổng tung ra khóa học 4 tiếng. Miễn phí.",
      "startSec": 13.54, "endSec": 15.72,
      "style": "solution",
      "highlights": ["4 tiếng", "Miễn phí"],
      "textEffect": "word-by-word"
    },
    {
      "text": "Dạy Claude AI từ con số 0 đến mức bạn xây được cả đội AI làm việc thay mình.",
      "startSec": 15.72, "endSec": 19.22,
      "style": "solution",
      "highlights": ["con số 0", "đội AI"],
      "textEffect": "word-by-word"
    },
    {
      "text": "4 tiếng này ổng dạy gì?",
      "startSec": 19.22, "endSec": 20.84,
      "style": "hook",
      "highlights": ["4 tiếng"],
      "textEffect": "word-by-word"
    },
    {
      "text": "Cách cài đặt lên máy tính — ai cũng làm được.",
      "startSec": 20.84, "endSec": 22.8,
      "style": "normal",
      "highlights": ["cài đặt"],
      "textEffect": "word-by-word"
    },
    {
      "text": "Cách tạo \"bộ não dự án\" — để AI hiểu ý bạn mà không cần giải thích lại mỗi lần.",
      "startSec": 22.8, "endSec": 26.54,
      "style": "normal",
      "highlights": ["bộ não dự án"],
      "textEffect": "word-by-word"
    },
    {
      "text": "Cách cho AI lập kế hoạch trước khi làm — một phút lên kế hoạch tiết kiệm cả tiếng sửa lỗi.",
      "startSec": 26.54, "endSec": 29.98,
      "style": "normal",
      "highlights": ["lập kế hoạch", "tiết kiệm cả tiếng"],
      "textEffect": "word-by-word"
    },
    {
      "text": "Và phần hay nhất — cách tạo ra cả một đội AI.",
      "startSec": 29.98, "endSec": 32.26,
      "style": "solution",
      "highlights": ["đội AI"],
      "textEffect": "word-by-word"
    },
    {
      "text": "Đứa đi nghiên cứu, đứa soi lỗi, đứa chạy thử.",
      "startSec": 32.26, "endSec": 34.08,
      "style": "solution",
      "highlights": [],
      "textEffect": "word-by-word"
    },
    {
      "text": "Giống như bạn có cả team nhân viên mà không tốn đồng lương nào.",
      "startSec": 34.08, "endSec": 37.22,
      "style": "solution",
      "highlights": ["team nhân viên", "không tốn đồng lương"],
      "textEffect": "word-by-word"
    },
    {
      "text": "Nói thật — khóa học 4 tiếng này chi tiết hơn 90% các khóa trả tiền mà mình từng thấy. Mà nó FREE.",
      "startSec": 37.22, "endSec": 41.38,
      "style": "hook",
      "highlights": ["90%", "FREE"],
      "textEffect": "word-by-word"
    },
    {
      "text": "Comment \"claude\" bên dưới — mình gửi link khóa học cho bạn nhé.",
      "startSec": 41.38, "endSec": 45.12,
