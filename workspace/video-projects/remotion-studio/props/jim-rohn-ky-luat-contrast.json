      "durationSec": 3.0,
      "fontSize": 48,
      "fontWeight": 700,
      "color": "#FFFFFF",
      "lineHeight": 1.4
    },
    {
      "lines": ["Dậy sớm thì mệt,", "nhưng lãng phí thời gian còn mệt hơn."],
