      "fontSize": 48,
      "fontWeight": 700,
      "color": "#FFD700",
      "lineHeight": 1.4
    },
    {
      "lines": ["Bắt đầu thì khó,", "nhưng không bắt đầu còn khó hơn."],
      "startSec": 7.2,
      "durationSec": 3.0,
      "fontSize": 48,
      "fontWeight": 700,
      "color": "#FFFFFF",
      "lineHeight": 1.4
    },
    {
      "lines": ["Kiên nhẫn thì chậm,", "nhưng bỏ cuộc thì mất tất cả."],
      "startSec": 10.4,
      "durationSec": 3.0,
      "fontSize": 48,
      "fontWeight": 700,
      "color": "#FFD700",
      "lineHeight": 1.4
    },
    {
      "lines": ["Thay đổi thì đau,", "nhưng mắc kẹt còn đau hơn."],
