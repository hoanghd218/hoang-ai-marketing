  "captions": [
    { "text": "CLAUDE AI GIỜ KHÔNG CÒN LÀ CHATBOT", "startSec": 0.7, "endSec": 3.76, "style": "hook", "textEffect": "slam", "highlights": ["CHATBOT"], "captionPosition": 70 },
    { "text": "Claude Code có 1 tính năng cực kỳ quan trọng", "startSec": 3.76, "endSec": 5.82, "style": "normal", "textEffect": "word-by-word", "highlights": ["quan trọng"], "captionPosition": 70 },
    { "text": "Giống như cánh tay nối dài của Claude", "startSec": 5.82, "endSec": 7.80, "style": "normal", "textEffect": "word-by-word", "highlights": ["cánh tay nối dài"], "captionPosition": 70 },
    { "text": "Kết nối vào các phần mềm khác để làm việc hộ mình", "startSec": 7.80, "endSec": 11.10, "style": "solution", "textEffect": "word-by-word", "highlights": ["làm việc hộ mình"], "captionPosition": 70 },
    { "text": "Chia sẻ 5 MCP mình hay dùng", "startSec": 11.10, "endSec": 13.14, "style": "hook", "textEffect": "slam", "highlights": ["5 MCP"], "captionPosition": 70 },
    { "text": "MCP mình hay dùng nè", "startSec": 13.58, "endSec": 15.08, "style": "normal", "textEffect": "word-by-word", "captionPosition": 70 },

    { "text": "Thứ nhất: GMAIL CONNECTOR", "startSec": 15.08, "endSec": 16.86, "style": "hook", "textEffect": "slam", "highlights": ["GMAIL"], "captionPosition": 70 },
    { "text": "Tự động phân loại email hàng ngày", "startSec": 16.86, "endSec": 19.28, "style": "normal", "textEffect": "word-by-word", "highlights": ["phân loại"], "captionPosition": 70 },
    { "text": "Lọc email quan trọng, soạn thư nháp để mình trả lời", "startSec": 19.28, "endSec": 22.20, "style": "normal", "textEffect": "word-by-word", "highlights": ["quan trọng", "nháp"], "captionPosition": 70 },
    { "text": "Kết hợp với tính năng Skills cực mạnh", "startSec": 22.20, "endSec": 23.74, "style": "normal", "textEffect": "word-by-word", "highlights": ["Skills"], "captionPosition": 70 },
    { "text": "Giờ mình phản hồi hoàn toàn tự động", "startSec": 23.74, "endSec": 25.14, "style": "solution", "textEffect": "word-by-word", "highlights": ["tự động"], "captionPosition": 70 },

    { "text": "Thứ hai: VERCEL MCP", "startSec": 25.14, "endSec": 27.54, "style": "hook", "textEffect": "slam", "highlights": ["VERCEL"], "captionPosition": 70 },
    { "text": "Nếu bạn làm việc với Claude Code sẽ mê cái này", "startSec": 27.54, "endSec": 30.06, "style": "normal", "textEffect": "word-by-word", "highlights": ["Claude Code"], "captionPosition": 70 },
    { "text": "Claude giờ deploy Vercel miễn phí", "startSec": 30.06, "endSec": 32.82, "style": "solution", "textEffect": "word-by-word", "highlights": ["miễn phí"], "captionPosition": 70 },
    { "text": "Không cần mở terminal, không cần git commit", "startSec": 32.82, "endSec": 34.82, "style": "normal", "textEffect": "word-by-word", "highlights": ["terminal", "git"], "captionPosition": 70 },
    { "text": "Cực dễ dùng cho anh chị không phải lập trình viên", "startSec": 34.82, "endSec": 37.68, "style": "normal", "textEffect": "word-by-word", "highlights": ["Cực dễ"], "captionPosition": 70 },

    { "text": "Thứ ba: MICROSOFT CLARITY MCP", "startSec": 37.68, "endSec": 40.06, "style": "hook", "textEffect": "slam", "highlights": ["CLARITY"], "captionPosition": 70 },
    { "text": "Dành riêng cho bạn chạy quảng cáo", "startSec": 40.06, "endSec": 41.94, "style": "normal", "textEffect": "word-by-word", "highlights": ["quảng cáo"], "captionPosition": 70 },
    { "text": "Claude phân tích hành vi User Session Recording", "startSec": 41.94, "endSec": 45.72, "style": "normal", "textEffect": "word-by-word", "highlights": ["hành vi"], "captionPosition": 70 },
